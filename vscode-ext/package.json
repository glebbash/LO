{
    "name": "lo",
    "displayName": "LO",
    "description": "LO language support",
    "author": "glebbash",
    "publisher": "glebbash",
    "license": "MIT",
    "version": "0.0.128",
    "engines": {
        "vscode": "^1.88.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/glebbash/lo"
    },
    "categories": [
        "Programming Languages"
    ],
    "icon": "assets/icons/lo_128px.png",
    "activationEvents": [],
    "main": "./dist/extension.js",
    "browser": "./dist/extension.js",
    "scripts": {
        "build": "tsup --minify",
        "dev": "tsup --watch",
        "dev-web": "npm run watch & node serve-web-ext.mjs"
    },
    "extensionDependencies": [
        "ms-vscode.wasm-wasi-core"
    ],
    "dependencies": {
        "@vscode/wasm-wasi": "^1.0.1"
    },
    "devDependencies": {
        "@types/vscode": "^1.88.0",
        "express": "^5.2.1",
        "tsup": "^8.5.1",
        "typescript": "^6.0.2",
        "vsce": "^2.15.0"
    },
    "contributes": {
        "languages": [
            {
                "id": "lo",
                "aliases": [
                    "lo"
                ],
                "extensions": [
                    ".lo"
                ],
                "configuration": "./syntaxes/lo.config.json",
                "icon": {
                    "light": "assets/icons/lo.svg",
                    "dark": "assets/icons/lo.svg"
                }
            }
        ],
        "grammars": [
            {
                "language": "lo",
                "scopeName": "source.lo",
                "path": "./syntaxes/lo.tmLanguage.json"
            }
        ],
        "commands": [
            {
                "command": "lo.initProject",
                "title": "LO: Initialize project in the current workspace"
            },
            {
                "command": "lo.runFile",
                "title": "LO: Run current file",
                "category": "LO",
                "icon": "$(debug-start)"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "lo.runFile",
                    "when": "editorLangId == lo",
                    "group": "navigation"
                }
            ]
        },
        "configuration": {
            "title": "LO",
            "properties": {
                "lo.compilerPath": {
                    "type": "string",
                    "default": "lo.wasm",
                    "description": "Path to the compiler, relative to workspace folder"
                },
                "lo.enableFormatting": {
                    "type": "boolean",
                    "default": true,
                    "description": "Registers formatting provider for LO files (this field change requires extension restart)"
                }
            }
        },
        "webShellMountPoints": [
            {
                "mountPoint": "/usr/bin/clear",
                "command": "lo.webshell.clear"
            },
            {
                "mountPoint": "/usr/bin/run",
                "command": "lo.webshell.run"
            }
        ]
    },
    "tsup": {
        "entry": [
            "src/extension.ts"
        ],
        "format": [
            "cjs"
        ],
        "external": [
            "vscode"
        ],
        "noExternal": [
            "@vscode/wasm-wasi"
        ],
        "sourcemap": true,
        "clean": true
    }
}
