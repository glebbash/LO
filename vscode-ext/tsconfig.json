{
    "include": ["src"],
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022", "WebWorker"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "sourceMap": true,
        "rootDir": "src",
        "outDir": "dist",
        "strict": true,
        "skipLibCheck": true
    }
}
